{
  "schema": "speedkit.public_control_release_certificate_policy.v1",
  "status": "LIVE",
  "rule": {
    "release_certificate_binds_release_archive_verifier": true,
    "release_certificate_binds_release_archive": true,
    "release_certificate_binds_release_seal_verifier": true,
    "release_certificate_binds_release_seal": true,
    "release_certificate_binds_public_only_counts": true,
    "release_certificate_hash_algorithm": "SHA-256",
    "release_certificate_hash_excludes_certified_at": true,
    "release_certificate_uses_public_material_only": true,
    "release_certificate_uses_release_archive_verifier_snapshot": true,
    "release_certificate_does_not_call_release_archive_verify_api": true,
    "release_certificate_does_not_call_release_archive_api": true,
    "release_certificate_avoids_same_origin_http_replay": true,
    "release_certificate_requires_archive_verified": true,
    "release_certificate_requires_archive_hash_ok": true,
    "release_certificate_requires_failures_zero": true,
    "release_certificate_requires_private_remaining_zero": true,
    "release_certificate_requires_system_count_four": true,
    "release_certificate_requires_workspace_count_135": true,
    "release_certificate_requires_route_count_floor": true,
    "release_certificate_returns_json_on_error": true,
    "release_certificate_no_uncaught_html_500": true,
    "checkout_remains_live": true,
    "public_surfaces_remain_public": true
  },
  "authority": {
    "public_control_release_certificate_api": "/api/marketplace/control-release-certificate",
    "public_control_release_certificate_page": "/marketplace/control-release-certificate/",
    "public_control_release_certificate_policy": "/marketplace/control-release-certificate-policy.json",
    "public_control_release_archive_verify_api": "/api/marketplace/control-release-archive-verify",
    "public_control_release_archive_api": "/api/marketplace/control-release-archive",
    "checkout_api": "/api/marketplace/checkout",
    "product_os_json": "/marketplace/product-os.json",
    "route_map_json": "/marketplace/route-map.json"
  }
}
